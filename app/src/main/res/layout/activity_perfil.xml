<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FAFAFA">

    <LinearLayout
        android:id="@+id/layoutHeaderPerfil"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="20dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/btnVolver"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:padding="8dp"
            android:src="@android:drawable/ic_menu_revert"
            app:tint="#0A4D34"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:contentDescription="Volver atrás" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Mi Perfil"
            android:textColor="#0A4D34"
            android:fontFamily="sans-serif-medium"
            android:textSize="22sp"
            android:layout_marginLeft="15dp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/layoutDatosUser"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:padding="20dp"
        app:layout_constraintTop_toBottomOf="@id/layoutHeaderPerfil">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tvPerfilNombre"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Cargando nombre..."
                android:textColor="#333333"
                android:textStyle="bold"
                android:textSize="24sp" />

            <ImageView
                android:id="@+id/ivPerfilRolIcono"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginStart="8dp"
                android:visibility="gone"
                android:contentDescription="Icono de Rol" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvPerfilEmail"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Cargando correo..."
            android:textColor="#777777"
            android:textSize="16sp"
            android:layout_marginTop="4dp" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:padding="20dp"
        app:layout_constraintTop_toBottomOf="@id/layoutDatosUser"
        app:layout_constraintBottom_toTopOf="@id/btnCerrarSesion">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Dirección de Entrega"
            android:textColor="#0A4D34"
            android:textStyle="bold"
            android:textSize="16sp"
            android:layout_marginBottom="8dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="20dp">

            <EditText
                android:id="@+id/etPerfilDireccion"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:layout_weight="1"
                android:background="@android:drawable/editbox_background_normal"
                android:hint="Calle, Número, Depto..."
                android:paddingLeft="15dp"
                android:textSize="16sp"
                android:enabled="false" />

            <ImageView
                android:id="@+id/btnEditarDireccion"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:padding="8dp"
                android:layout_marginStart="5dp"
                android:src="@android:drawable/ic_menu_edit"
                app:tint="#0A4D34"
                android:contentDescription="Editar dirección" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Teléfono de Contacto"
            android:textColor="#0A4D34"
            android:textStyle="bold"
            android:textSize="16sp"
            android:layout_marginBottom="8dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="30dp">

            <EditText
                android:id="@+id/etPerfilTelefono"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:layout_weight="1"
                android:background="@android:drawable/editbox_background_normal"
                android:hint="Ej: +54 9 11..."
                android:inputType="phone"
                android:paddingLeft="15dp"
                android:textSize="16sp"
                android:enabled="false" />

            <ImageView
                android:id="@+id/btnEditarTelefono"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:padding="8dp"
                android:layout_marginStart="5dp"
                android:src="@android:drawable/ic_menu_edit"
                app:tint="#0A4D34"
                android:contentDescription="Editar teléfono" />
        </LinearLayout>

        <Button
            android:id="@+id/btnGuardarDatos"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:text="Guardar Cambios"
            android:backgroundTint="#0A4D34"
            android:textColor="#FFFFFF"
            android:visibility="gone" />
    </LinearLayout>

    <Button
        android:id="@+id/btnCerrarSesion"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:layout_margin="20dp"
        android:text="Cerrar Sesión"
        android:backgroundTint="#D32F2F"
        android:textColor="#FFFFFF"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>