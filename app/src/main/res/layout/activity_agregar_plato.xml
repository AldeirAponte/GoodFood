<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="#FAFAFA">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:id="@+id/tvTituloAdmin"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            android:text="Panel de Administrador\nAgregar Nuevo Plato"
            android:textColor="#2E7D32"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textAlignment="center"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Nombre de la vianda"
            android:textColor="#555555"
            android:textStyle="bold"
            android:layout_marginBottom="4dp"/>

        <EditText
            android:id="@+id/etNombreNuevo"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:background="@android:drawable/edit_text"
            android:hint="Ej: Ensalada César Premium"
            android:inputType="textPersonName"
            android:padding="10dp"
            android:layout_marginBottom="16dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Descripción de los ingredientes"
            android:textColor="#555555"
            android:textStyle="bold"
            android:layout_marginBottom="4dp"/>

        <EditText
            android:id="@+id/etDescripcionNuevo"
            android:layout_width="match_parent"
            android:layout_height="80dp"
            android:background="@android:drawable/edit_text"
            android:hint="Ej: Mix de verdes, pollo, croutons..."
            android:inputType="textMultiLine"
            android:gravity="top|start"
            android:padding="10dp"
            android:layout_marginBottom="16dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Precio ($)"
            android:textColor="#555555"
            android:textStyle="bold"
            android:layout_marginBottom="4dp"/>

        <EditText
            android:id="@+id/etPrecioNuevo"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:background="@android:drawable/edit_text"
            android:hint="Ej: 4500"
            android:inputType="numberDecimal"
            android:padding="10dp"
            android:layout_marginBottom="16dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Foto del Plato"
            android:textColor="#555555"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"/>

        <ImageView
            android:id="@+id/imgPrevisualizacion"
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:layout_gravity="center"
            android:background="#E0E0E0"
            android:scaleType="centerCrop"
            android:layout_marginBottom="8dp"
            android:contentDescription="Vista previa" />

        <Button
            android:id="@+id/btnSeleccionarFoto"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="Seleccionar Foto"
            android:backgroundTint="#757575"
            android:layout_marginBottom="24dp"/>

        <Button
            android:id="@+id/btnGuardarPlato"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:text="GUARDAR PLATO EN EL MENÚ"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:backgroundTint="#2E7D32" />

    </LinearLayout>
</ScrollView>